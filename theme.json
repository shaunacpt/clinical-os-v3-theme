{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "color": {
      "palette": [
        {
          "slug": "navy",
          "color": "#1B263B",
          "name": "Clinical Navy"
        },
        {
          "slug": "teal",
          "color": "#81D4A8",
          "name": "Clinical Teal"
        },
        {
          "slug": "mint",
          "color": "#E8F5E9",
          "name": "Clinical Mint"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "gray",
          "color": "#f8f9fa",
          "name": "Soft Gray"
        },
        {
          "slug": "accent",
          "color": "#00C2CB",
          "name": "Accent Teal"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"Heebo\", sans-serif",
          "name": "Heebo",
          "slug": "heebo"
        },
        {
          "fontFamily": "\"Outfit\", sans-serif",
          "name": "Outfit",
          "slug": "outfit"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--navy)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--heebo)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--outfit)",
          "fontWeight": "700"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--outfit)",
          "fontWeight": "600"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--outfit)",
          "fontWeight": "600"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--outfit)",
          "fontWeight": "600"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--outfit)",
          "fontWeight": "600"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--outfit)",
          "fontWeight": "600"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--teal)"
        }
      }
    }
  }
}
